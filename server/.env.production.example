# Railway 后端环境变量模板
# 复制此文件为 .env.production 并填入实际值

# OpenRouter API Key（必需）
OPENROUTER_API_KEY=sk-or-v1-your_key_here

# Twitter API（可选）
TWITTER_API_KEY=

# 邮件通知（可选）
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL=

# 客户端 URL（部署后填入前端地址）
CLIENT_URL=https://your-frontend.pages.dev

# 节点环境
NODE_ENV=production
PORT=3001